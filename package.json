{
  "name": "le-poulailler",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-pwa-icons.mjs && node scripts/generate-firebase-sw.mjs",
    "predev": "node scripts/generate-firebase-sw.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "generate-guide-pdf": "node scripts/generate-guide-pdf.mjs",
    "sync-mobile-assets": "node scripts/sync-mobile-assets.mjs",
    "mobile": "npm run sync-mobile-assets && cd mobile && npm start",
    "mobile:install": "npm run sync-mobile-assets && cd mobile && npm install",
    "server:install": "cd server && npm install",
    "server": "cd server && npm start",
    "server:dev": "cd server && npm run dev"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "firebase": "^12.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "pdfkit": "^0.16.0",
    "sharp": "^0.33.5",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1"
  }
}
